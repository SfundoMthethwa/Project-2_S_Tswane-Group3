<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Campus Gig - Notifications</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; }
        .sidebar { background: #1a3c5e; color: white; height: 100vh; position: fixed; left: 0; top: 0; width: 280px; padding: 30px 20px; }
        .sidebar-logo { text-align: center; margin-bottom: 40px; }
        .sidebar-logo i { font-size: 60px; background: rgba(255,255,255,0.1); padding: 15px; border-radius: 50%; }
        .sidebar-logo h3 { color: white; margin-top: 15px; }
        .sidebar-logo p { color: #ffc107; font-size: 12px; }
        .sidebar-menu { list-style: none; padding: 0; }
        .sidebar-menu li { margin-bottom: 15px; }
        .sidebar-menu a { color: white; text-decoration: none; display: flex; align-items: center; padding: 12px 15px; border-radius: 10px; transition: 0.3s; }
        .sidebar-menu a i { margin-right: 12px; font-size: 20px; }
        .sidebar-menu a:hover { background: rgba(255,255,255,0.1); }
        .sidebar-menu a.active { background: #ffc107; color: #1a3c5e; }
        .main-content { margin-left: 280px; padding: 20px 40px; }
        .notifications-container { background: white; border-radius: 20px; padding: 30px; box-shadow: 0 5px 15px rgba(0,0,0,0.08); }
        .notification-item { border-left: 4px solid #ffc107; padding: 15px; margin-bottom: 15px; background: #f8f9fa; border-radius: 10px; transition: 0.3s; }
        .notification-item:hover { transform: translateX(5px); background: #e9ecef; }
        .notification-item.unread { background: #fff3cd; border-left-color: #ffc107; }
        .notification-time { font-size: 12px; color: #6c757d; margin-top: 5px; }
        .mark-read-btn { background: #1a3c5e; color: white; border: none; padding: 10px 20px; border-radius: 10px; cursor: pointer; margin-bottom: 20px; }
        .mark-read-btn:hover { background: #2c5a7a; }
        .footer { background: #1a3c5e; color: white; padding: 30px; text-align: center; border-radius: 15px; margin-top: 40px; }
        @media (max-width: 768px) { .sidebar { width: 80px; padding: 20px 10px; } .sidebar-logo h3, .sidebar-logo p, .sidebar-menu a span { display: none; } .sidebar-menu a i { margin-right: 0; } .main-content { margin-left: 80px; padding: 20px; } }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-logo"><i class="bi-mortarboard-fill"></i><h3>Campus Gig</h3><p>Grow Smart. Grow Within.</p></div>
        <ul class="sidebar-menu">
            <li><a href="#"><i class="bi-house-door-fill"></i><span> Dashboard</span></a></li>
            <li><a href="#"><i class="bi-search"></i><span> Find Jobs</span></a></li>
            <li><a href="#"><i class="bi-briefcase"></i><span> My Applications</span></a></li>
            <li><a href="#"><i class="bi-person"></i><span> Profile</span></a></li>
            <li><a href="#"><i class="bi-gear"></i><span> Settings</span></a></li>
            <li><a href="#" class="active"><i class="bi-bell"></i><span> Notifications</span></a></li>
            <li><a href="login.html"><i class="bi-box-arrow-right"></i><span> Logout</span></a></li>
        </ul>
    </div>
    <div class="main-content">
        <div class="notifications-container">
            <h2><i class="bi-bell me-2"></i> Notifications</h2>
            <button class="mark-read-btn" onclick="markAllAsRead()">Mark All as Read</button>
            <div id="notificationsList">
                <div class="notification-item unread">
                    <div><strong>New job posted!</strong> - Retail Assistant at Fashion World</div>
                    <div class="notification-time">2 hours ago</div>
                </div>
                <div class="notification-item unread">
                    <div><strong>Application viewed</strong> - Your application for Barista at Coffee Haven has been viewed</div>
                    <div class="notification-time">Yesterday</div>
                </div>
                <div class="notification-item">
                    <div><strong>Interview scheduled</strong> - Data Capturer at DataTech Solutions</div>
                    <div class="notification-time">March 25, 2026</div>
                </div>
                <div class="notification-item">
                    <div><strong>New job alert</strong> - Math Tutor positions available in your area</div>
                    <div class="notification-time">March 22, 2026</div>
                </div>
            </div>
        </div>
        <div class="footer"><p>&copy; 2026 Campus Gig - All Rights Reserved.</p></div>
    </div>
    <script>
        function markAllAsRead() {
            const notifications = document.querySelectorAll('.notification-item');
            notifications.forEach(notification => {
                notification.classList.remove('unread');
            });
            alert('All notifications marked as read');
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
